from PyInstaller.utils.hooks import collect_all

datas, binaries, hiddenimports = collect_all('fastmcp')
hiddenimports += ['charset_normalizer']

a = Analysis(
    ['supervisor\\main.py'],
    pathex=[],
    binaries=binaries,
    datas=datas + [('supervisor/prompts', 'prompts')],
    hiddenimports=hiddenimports,
    hookspath=[],
    hooksconfig={},
    runtime_hooks=[],
    excludes=[],
    noarchive=False,
    optimize=0,
)
pyz = PYZ(a.pure)

exe = EXE(
    pyz,
    a.scripts,
    a.binaries,
    a.datas,
    [],
    name='multi_agent',
    debug=False,
    bootloader_ignore_signals=False,
    strip=False,
    upx=True,
    upx_exclude=[],
    runtime_tmpdir=None,
    console=True,
    disable_windowed_traceback=False,
    argv_emulation=False,
    target_arch=None,
    codesign_identity=None,
    entitlements_file=None,
    icon=['app_icon.ico'],
)
