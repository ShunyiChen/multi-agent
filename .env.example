# =================================================================
# 核心 API 私钥 (Local environment variables — do NOT commit real keys)
# =================================================================

# DeepSeek API 密钥 (用于 dbhub_agent 和 kubernetes_agent 的默认模型)
DEEPSEEK_API_KEY=sk-********************

# Tavily API 密钥 (用于搜索增强)
TAVILY_API_KEY=tvly-dev-********************

# OpenAI API 密钥 (备用或特定工具集成)
OPENAI_API_KEY=sk-proj-********************

# NVIDIA API 密钥 (用于通过 NVIDIA AI Endpoints 运行特定模型)
NVIDIA_API_KEY=nvapi-********************

# =================================================================
# MCP 服务端配置
# =================================================================

# MCP (Model Context Protocol) 服务的 IP 地址或主机名
# 如果在本地运行，请设置为 localhost
# 如果在远程设备或 Docker 容器外运行，请输入对应的 IP 地址
DBHUB_MCP_SERVER_IP_ADDRESS=127.0.0.1
DBHUB_MCP_SERVER_PORT=8080

K8S_MCP_SERVER_IP_ADDRESS=127.0.0.1
K8S_MCP_SERVER_PORT=8888

